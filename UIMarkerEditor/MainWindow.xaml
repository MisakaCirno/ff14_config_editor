<Window x:Class="UIMarkerEditor.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UIMarkerEditor"
        xmlns:controls="clr-namespace:UIMarkerEditor.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="FF14 标点预设编辑工具"
        Height="600" Width="1000"
        MinHeight="600" MinWidth="1000"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.OpenWayMarkFileCommand}"
                        Executed="OpenWayMarkFileCommand_Executed"
                        CanExecute="OpenWayMarkFileCommand_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.ReloadWayMarkFileCommand}"
                        Executed="ReloadWayMarkFileCommand_Executed"
                        CanExecute="CurrentWayMarkFileCommand_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.SaveWayMarkFileCommand}"
                        Executed="SaveWayMarkFileCommand_Executed"
                        CanExecute="CurrentWayMarkFileCommand_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.CloseWayMarkFileCommand}"
                        Executed="CloseWayMarkFileCommand_Executed"
                        CanExecute="CurrentWayMarkFileCommand_CanExecute"/>
    </Window.CommandBindings>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0,38,0,0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFF7FAFC"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                                    </Style>
                                    <Style TargetType="{x:Type AccessText}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF3E536B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF263646"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                                    </Style>
                                    <Style TargetType="{x:Type AccessText}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFC50F1F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Margin" Value="2,5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#FFF7FAFC"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border x:Name="MenuItemBorder"
                                    Background="Transparent"
                                    CornerRadius="5">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Margin="{TemplateBinding Padding}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        BorderBrush="{StaticResource AppBorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="150"
                                        Padding="3"
                                        SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#FF3E536B"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#FF263646"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarSubMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="145"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border x:Name="MenuItemBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="1">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="{StaticResource AppMutedTextBrush}"
                                               Margin="24,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="2"
                                          Data="M 0 0 L 4 4 L 0 8 Z"
                                          Fill="{StaticResource AppMutedTextBrush}"
                                          Margin="12,0,0,0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        BorderBrush="{StaticResource AppBorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="180"
                                        Padding="3"
                                        SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{StaticResource MainTabItem.MouseOver.Background}"/>
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="{StaticResource MainTabItem.Selected.Border}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{StaticResource MainTabItem.MouseOver.Background}"/>
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="{StaticResource MainTabItem.Selected.Border}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCheckableSubMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="190"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border x:Name="MenuItemBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="1">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CheckMark_TextBlock"
                                               Text="✓"
                                               Foreground="{StaticResource AppAccentPressedBrush}"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="{StaticResource AppMutedTextBrush}"
                                               Margin="24,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="3"
                                          Data="M 0 0 L 4 4 L 0 8 Z"
                                          Fill="{StaticResource AppMutedTextBrush}"
                                          Margin="12,0,0,0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        BorderBrush="{StaticResource AppBorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="180"
                                        Padding="3"
                                        SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark_TextBlock" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{StaticResource MainTabItem.MouseOver.Background}"/>
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="{StaticResource MainTabItem.Selected.Border}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{StaticResource MainTabItem.MouseOver.Background}"/>
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="{StaticResource MainTabItem.Selected.Border}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar_Border"
                Grid.Row="0"
                Background="#FF2F4054"
                BorderBrush="#FF243244"
                BorderThickness="0,0,0,1"
                CornerRadius="0"
                Grid.IsSharedSizeScope="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="TitleBarSide"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="TitleBarSide"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleTextBlock"
                               Grid.Column="1"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="#FFF7FAFC"
                               Padding="0"
                               Margin="12,0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               IsHitTestVisible="False"/>

                <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                    <Image Source="Assets/Image/s_a.png"
                               Margin="2"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Menu Background="Transparent"
                              BorderThickness="0"
                              VerticalAlignment="Center"
                              ItemContainerStyle="{StaticResource TitleBarMenuItemStyle}"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <MenuItem x:Name="File_MenuItem"
                                      Header="文件"
                                      SubmenuOpened="File_MenuItem_SubmenuOpened">
                            <MenuItem Header="读取"
                                          Style="{StaticResource TitleBarSubMenuItemStyle}"
                                          Command="{x:Static local:MainWindow.OpenWayMarkFileCommand}"
                                          CommandTarget="{Binding ElementName=RootWindow}"
                                          InputGestureText="Ctrl+O"/>
                            <MenuItem x:Name="OpenLocalCharacter_MenuItem"
                                      Header="直接选择游戏角色..."
                                      Style="{StaticResource TitleBarSubMenuItemStyle}"
                                      Click="OpenLocalCharacter_MenuItem_Click"
                                      Visibility="Collapsed"/>
                            <MenuItem x:Name="RecentFiles_MenuItem"
                                          Header="最近打开"
                                          Style="{StaticResource TitleBarSubMenuItemStyle}"/>
                            <Separator/>
                            <MenuItem Header="保存"
                                          Style="{StaticResource TitleBarSubMenuItemStyle}"
                                          Command="{x:Static local:MainWindow.SaveWayMarkFileCommand}"
                                          CommandTarget="{Binding ElementName=RootWindow}"
                                          InputGestureText="Ctrl+S"/>
                            <MenuItem Header="重新加载"
                                           Style="{StaticResource TitleBarSubMenuItemStyle}"
                                           Command="{x:Static local:MainWindow.ReloadWayMarkFileCommand}"
                                           CommandTarget="{Binding ElementName=RootWindow}"
                                           InputGestureText="Ctrl+R"/>
                            <MenuItem Header="关闭当前文件"
                                          Style="{StaticResource TitleBarSubMenuItemStyle}"
                                          Command="{x:Static local:MainWindow.CloseWayMarkFileCommand}"
                                          CommandTarget="{Binding ElementName=RootWindow}"
                                          InputGestureText="Ctrl+W"/>
                            <Separator/>
                            <MenuItem Header="退出"
                                          Style="{StaticResource TitleBarSubMenuItemStyle}"
                                          InputGestureText="Alt+F4"
                                          Click="ExitMenuItem_Click"/>
                        </MenuItem>
                        <MenuItem x:Name="QuickSettings_MenuItem"
                                  Header="快捷设置"
                                  SubmenuOpened="QuickSettings_MenuItem_SubmenuOpened">
                            <MenuItem x:Name="MapDataSource_MenuItem"
                                      Header="数据来源"
                                      Style="{StaticResource TitleBarSubMenuItemStyle}">
                                <MenuItem x:Name="OnlineReferenceMapDataSource_MenuItem"
                                          Header="在线数据（不读取游戏文件）"
                                          IsCheckable="True"
                                          Style="{StaticResource TitleBarCheckableSubMenuItemStyle}"
                                          Click="OnlineReferenceMapDataSource_MenuItem_Click"/>
                                <MenuItem x:Name="LocalGameMapDataSource_MenuItem"
                                          Header="本地游戏数据（读取本地游戏文件）"
                                          IsCheckable="True"
                                          Style="{StaticResource TitleBarCheckableSubMenuItemStyle}"
                                          Click="LocalGameMapDataSource_MenuItem_Click"/>
                                <MenuItem x:Name="ManualMapDataTableMode_MenuItem"
                                          Header="用户填写数据（mapdata_user.csv）"
                                          IsCheckable="True"
                                          Style="{StaticResource TitleBarCheckableSubMenuItemStyle}"
                                          Click="ManualMapDataTableMode_MenuItem_Click"/>
                                <Separator/>
                                <MenuItem x:Name="EditUserMapData_MenuItem"
                                          Header="编辑用户填写数据..."
                                          Style="{StaticResource TitleBarSubMenuItemStyle}"
                                          Click="EditUserMapData_MenuItem_Click"/>
                            </MenuItem>
                            <MenuItem x:Name="UnknownMapIdPolicy_MenuItem"
                                      Header="地图ID限制"
                                      Style="{StaticResource TitleBarSubMenuItemStyle}">
                                <MenuItem x:Name="RejectUnknownMapId_MenuItem"
                                          Header="不允许未知地图 ID"
                                          IsCheckable="True"
                                          Style="{StaticResource TitleBarCheckableSubMenuItemStyle}"
                                          Click="RejectUnknownMapId_MenuItem_Click"/>
                                <MenuItem x:Name="AllowUnknownMapId_MenuItem"
                                          Header="允许未知地图 ID"
                                          IsCheckable="True"
                                          Style="{StaticResource TitleBarCheckableSubMenuItemStyle}"
                                          Click="AllowUnknownMapId_MenuItem_Click"/>
                            </MenuItem>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                    <Button x:Name="MinimizeWindow_Button"
                                Style="{StaticResource TitleBarButtonStyle}"
                                ToolTip="最小化"
                                Click="MinimizeWindow_Button_Click">
                        <Path Width="10"
                                  Height="1"
                                  Data="{StaticResource WindowMinimizeIconGeometry}"
                                  Stretch="Fill"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1"/>
                    </Button>
                    <Button x:Name="MaximizeRestoreWindow_Button"
                                Style="{StaticResource TitleBarButtonStyle}"
                                ToolTip="最大化"
                                Click="MaximizeRestoreWindow_Button_Click">
                        <Grid Width="10" Height="10">
                            <Path x:Name="MaximizeIcon_Path"
                                      Data="{StaticResource WindowMaximizeIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1"
                                      Fill="Transparent"/>
                            <Path x:Name="RestoreIcon_Path"
                                      Data="{StaticResource WindowRestoreIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1"
                                      Fill="Transparent"
                                      Visibility="Collapsed"/>
                        </Grid>
                    </Button>
                    <Button x:Name="CloseWindow_Button"
                                Style="{StaticResource TitleBarCloseButtonStyle}"
                                ToolTip="关闭"
                                Click="CloseWindow_Button_Click">
                        <Path Width="10"
                                  Height="10"
                                  Data="{StaticResource WindowCloseIconGeometry}"
                                  Stretch="Fill"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTab_Control"
                        Grid.Row="1"
                        ItemContainerStyle="{StaticResource MainTabItemStyle}"
                        Style="{StaticResource MainTabControlStyle}"
                        SelectionChanged="MainTab_Control_SelectionChanged">
            <TabItem Header="标点编辑">
                <controls:WayMarkEditorControl x:Name="WayMarkEditor_Control"/>
            </TabItem>

            <TabItem x:Name="WayMarkFavorites_TabItem" Header="标点收藏">
                <controls:WayMarkFavoritesControl x:Name="WayMarkFavorites_Control"/>
            </TabItem>

            <TabItem Header="备份还原">
                <controls:BackupRestoreControl x:Name="BackupRestore_Control"/>
            </TabItem>

            <TabItem x:Name="CharacterProfiles_TabItem" Header="角色备注">
                <controls:CharacterProfilesControl x:Name="CharacterProfiles_Control"/>
            </TabItem>

            <TabItem x:Name="ToolSettings_TabItem" Header="工具设置">
                <controls:ToolSettingsControl x:Name="ToolSettings_Control"/>
            </TabItem>

            <TabItem Header="帮助与关于">
                <controls:HelpAboutControl/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                    Background="#FFEEF4F7"
                    BorderBrush="#FFD7E4EA"
                    BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="当前文件："
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Padding="10,0,0,0"
                               VerticalAlignment="Center"/>
                <TextBlock x:Name="CurrentFileStatus_TextBlock"
                               Grid.Column="1"
                               Text="未加载 UISAVE 文件"
                               ToolTip="未加载 UISAVE 文件"
                               Foreground="{StaticResource AppTextBrush}"
                               Padding="0,0,10,0"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               TextAlignment="Left"
                               TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <ItemsControl x:Name="ToastItems_Control"
                      Grid.RowSpan="3"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,54,16,0"
                      Panel.ZIndex="100"
                      IsHitTestVisible="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border MinWidth="220"
                            MaxWidth="360"
                            Background="#F8FFFFFF"
                            BorderBrush="{StaticResource AppSuccessButtonBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,9"
                            Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14"
                                              ShadowDepth="2"
                                              Opacity="0.18"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="√"
                                       Foreground="{StaticResource AppSuccessButtonBrush}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Message}"
                                       Foreground="{StaticResource AppTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <controls:BusyOverlayControl x:Name="MapDataOperationOverlay_Control"
                                     Grid.RowSpan="3"
                                     Panel.ZIndex="200"/>
    </Grid>
</Window>
