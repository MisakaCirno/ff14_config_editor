<Window x:Class="UIMarkerEditor.BackupCharacterProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="创建角色备注"
        Height="360"
        Width="460"
        MinHeight="360"
        MinWidth="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="为选中的备份创建角色备注。"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1"
                   Text="User ID："
                   VerticalAlignment="Center"
                   Margin="0,0,8,8"/>
        <TextBox x:Name="UserID_TextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 IsReadOnly="True"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2"
                   Text="角色名："
                   VerticalAlignment="Center"
                   Margin="0,0,8,8"/>
        <TextBox x:Name="CharacterName_TextBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3"
                   Text="服务器："
                   VerticalAlignment="Center"
                   Margin="0,0,8,8"/>
        <Grid Grid.Row="3"
              Grid.Column="1"
              Margin="0,0,0,8">
            <Button x:Name="ServerPicker_Button"
                    HorizontalContentAlignment="Stretch"
                    Click="ServerPicker_Button_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ServerPicker_TextBlock"
                               Text="请选择服务器"
                               TextAlignment="Left"/>
                    <TextBlock Grid.Column="1"
                               Text="▼"
                               FontSize="10"
                               Margin="8,0,0,0"/>
                </Grid>
            </Button>
            <Popup x:Name="ServerPicker_Popup"
                   PlacementTarget="{Binding ElementName=ServerPicker_Button}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="White"
                        BorderBrush="#FF888888"
                        BorderThickness="1"
                        Padding="6"
                        Width="{Binding ActualWidth, ElementName=ServerPicker_Button}"
                        MinWidth="360">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="ServerArea_ListBox"
                                 DisplayMemberPath="DataCenter"
                                 SelectionChanged="ServerArea_ListBox_SelectionChanged"/>
                        <ListBox x:Name="ServerWorld_ListBox"
                                 Grid.Column="1"
                                 SelectionChanged="ServerWorld_ListBox_SelectionChanged"/>
                    </Grid>
                </Border>
            </Popup>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="备注："
                   VerticalAlignment="Top"
                   Margin="0,4,8,0"/>
        <TextBox x:Name="Note_TextBox"
                 Grid.Row="4"
                 Grid.Column="1"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,4,0,8"/>

        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="确定"
                    Width="82"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Button_Click"/>
            <Button Content="取消"
                    Width="82"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
