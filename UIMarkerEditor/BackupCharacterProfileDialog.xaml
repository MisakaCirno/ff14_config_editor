<Window x:Class="UIMarkerEditor.BackupCharacterProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UIMarkerEditor.Controls"
        Title="创建角色备注"
        Height="360"
        Width="460"
        MinHeight="360"
        MinWidth="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="为选中的备份创建角色备注。"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1"
                   Text="User ID："
                   VerticalAlignment="Center"
                   Margin="0,0,8,8"/>
        <TextBox x:Name="UserID_TextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 IsReadOnly="True"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2"
                   Text="角色名："
                   VerticalAlignment="Center"
                   Margin="0,0,8,8"/>
        <TextBox x:Name="CharacterName_TextBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3"
                   Text="服务器："
                   VerticalAlignment="Center"
                   Margin="0,0,8,8"/>
        <controls:ServerPickerControl x:Name="ServerPicker_Control"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4"
                   Text="备注："
                   VerticalAlignment="Top"
                   Margin="0,4,8,0"/>
        <TextBox x:Name="Note_TextBox"
                 Grid.Row="4"
                 Grid.Column="1"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,4,0,8"/>

        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="确定"
                    Width="82"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Button_Click"/>
            <Button Content="取消"
                    Width="82"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
