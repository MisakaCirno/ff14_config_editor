<UserControl x:Class="UIMarkerEditor.Controls.ToolSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UIMarkerEditor.Controls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/ToolSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="4"
                Margin="0,0,8,0"
                VerticalAlignment="Stretch">
            <ListBox x:Name="SettingsNavigation_ListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource SettingsNavigationItemStyle}"
                     PreviewMouseLeftButtonDown="SettingsNavigation_ListBox_PreviewMouseLeftButtonDown"
                     SelectionChanged="SettingsNavigation_ListBox_SelectionChanged">
                <ListBoxItem Content="工具数据目录" Tag="DataStorage_Section"/>
                <ListBoxItem Content="文件打开" Tag="FileOpen_Section"/>
                <ListBoxItem Content="日志" Tag="Log_Section"/>
                <ListBoxItem Content="外观" Tag="Appearance_Section"/>
                <ListBoxItem Content="标点收藏" Tag="WayMarkFavorites_Section"/>
                <ListBoxItem Content="启动行为" Tag="StartupBehavior_Section"/>
                <ListBoxItem Content="自动备份" Tag="AutoBackup_Section"/>
                <ListBoxItem Content="数据同步" Tag="OnlineData_Section"/>
            </ListBox>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="SettingsContent_ScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="SettingsContent_ScrollViewer_ScrollChanged">
                <StackPanel>
                    <GroupBox x:Name="DataStorage_Section"
                              Header="工具数据目录"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="这里管理工具自己的可迁移数据。设置、备份、缓存和日志保存在下方数据目录中；启动配置和迁移进度是固定辅助文件，不属于迁移对象。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel x:Name="BootstrapFilePath_Label"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="启动配置"
                                               Style="{StaticResource SettingsFormLabelStyle}"/>
                                    <TextBlock Text="?"
                                               Foreground="{StaticResource AppMutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="-8,0,12,0"
                                               ToolTip="bootstrap.json 固定保存在启动配置目录，记录当前数据目录的位置；工具启动时先读取它来定位数据目录。"/>
                                </StackPanel>
                                <TextBox x:Name="BootstrapFilePath_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"
                                         Foreground="{StaticResource AppMutedTextBrush}"
                                         ToolTip="bootstrap.json 固定保存在启动配置目录，记录当前数据目录的位置；工具启动时先读取它来定位数据目录。"/>

                                <StackPanel x:Name="MigrationStateFilePath_Label"
                                            Grid.Row="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="迁移进度"
                                               Style="{StaticResource SettingsFormLabelStyle}"/>
                                    <TextBlock Text="?"
                                               Foreground="{StaticResource AppMutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="-8,0,12,0"
                                               ToolTip="migration-state.json 只在迁移未完成或需要恢复时存在，记录旧目录、新目录、复制校验和旧目录清理进度；迁移完全结束后会自动删除。"/>
                                </StackPanel>
                                <TextBox x:Name="MigrationStateFilePath_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"
                                         Foreground="{StaticResource AppMutedTextBrush}"
                                         ToolTip="migration-state.json 只在迁移未完成或需要恢复时存在，记录旧目录、新目录、复制校验和旧目录清理进度；迁移完全结束后会自动删除。"/>

                                <Separator Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Margin="0,8,0,8"/>

                                <TextBlock Grid.Row="3"
                                           Text="数据目录"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <TextBox x:Name="DataDirectory_TextBox"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="4"
                                           Text="目录操作"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,0">
                                    <Button Content="迁移到其他目录..."
                                            Click="BrowseDataDirectory_Button_Click"/>
                                    <Button Content="迁移回默认目录"
                                            Click="ResetDataDirectory_Button_Click"/>
                                    <Button Content="打开当前目录"
                                            Click="OpenDataDirectory_Button_Click"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="选择新目录或恢复默认目录会先进入迁移确认，再执行复制、校验、切换和旧目录清理。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="100,4,0,4"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="FileOpen_Section"
                              Header="文件打开"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="选择 UISAVE.DAT 时，文件选择器默认进入的位置。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Text="游戏安装目录"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <TextBlock Text="保存最终幻想 XIV 的安装根目录；也可以填写 game 目录或 ffxiv_dx11.exe，保存时会自动规范化为安装根目录。工具启动时会尝试从注册表自动读取，也可以扫描当前运行中的游戏；无法读取时请手动填写。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="0,-4,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="GameInstallDirectory_TextBox"
                                         HorizontalContentAlignment="Left"
                                         TextAlignment="Left"
                                         LostFocus="GameInstallDirectory_TextBox_LostFocus"
                                         PreviewKeyDown="GameInstallDirectory_TextBox_PreviewKeyDown"/>
                                <Button x:Name="ScanRunningGameInstallDirectory_Button"
                                        Grid.Column="1"
                                        Content="扫描运行中的游戏"
                                        Margin="8,0,0,0"
                                        Click="ScanRunningGameInstallDirectory_Button_Click"/>
                            </Grid>

                            <TextBlock Text="打开位置"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <RadioButton x:Name="OpenDirectoryDefault_RadioButton"
                                         GroupName="WayMarkOpenDirectoryMode"
                                         Content="默认"
                                         Margin="0,0,0,8"
                                         Checked="OpenDirectoryMode_RadioButton_Checked"/>
                            <TextBlock Text="使用 Windows 文件选择器记住的位置。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="22,-4,0,10"/>

                            <RadioButton x:Name="OpenDirectoryGameCharacter_RadioButton"
                                         GroupName="WayMarkOpenDirectoryMode"
                                         Content="游戏角色目录"
                                         Margin="0,0,0,8"
                                         Checked="OpenDirectoryMode_RadioButton_Checked"/>
                            <TextBlock Text="使用游戏安装目录下的 game\My Games\FINAL FANTASY XIV - A Realm Reborn 目录。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="22,-4,0,8"/>
                            <TextBox x:Name="GameCharacterDirectory_TextBox"
                                     Style="{StaticResource SettingsReadOnlyTextBoxStyle}"
                                     Margin="22,0,0,10"/>

                            <RadioButton x:Name="OpenDirectoryCustom_RadioButton"
                                         GroupName="WayMarkOpenDirectoryMode"
                                         Content="自定义目录"
                                         Margin="0,0,0,8"
                                         Checked="OpenDirectoryMode_RadioButton_Checked"/>
                            <TextBlock Text="使用你指定的目录。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="22,-4,0,8"/>
                            <Grid Margin="22,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="WayMarkCustomDirectory_TextBox"
                                         HorizontalContentAlignment="Left"
                                         TextAlignment="Left"
                                         LostFocus="WayMarkCustomDirectory_TextBox_LostFocus"
                                         PreviewKeyDown="WayMarkCustomDirectory_TextBox_PreviewKeyDown"/>
                                <Button x:Name="BrowseWayMarkCustomDirectory_Button"
                                        Grid.Column="1"
                                        Content="选择目录..."
                                        Margin="8,0,0,0"
                                        Click="BrowseWayMarkCustomDirectory_Button_Click"/>
                            </Grid>

                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="Log_Section"
                              Header="日志"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="日志保存在工具数据目录下的 logs 目录，用于排查同步、读取和保存问题。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="当前写入"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <TextBox x:Name="CurrentLogFilePath_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Text="日志操作"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,8">
                                    <Button Content="归档当前日志"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ArchiveCurrentLog_Button_Click"/>
                                    <Button Content="清理当前日志"
                                            Style="{StaticResource WarningButtonStyle}"
                                            Click="ClearCurrentLog_Button_Click"/>
                                    <Button Content="清理所有日志"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Click="ClearAllLogs_Button_Click"/>
                                    <Button Content="打开日志目录"
                                            Click="OpenLogDirectory_Button_Click"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="单个文件大小"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <TextBox x:Name="MaxLogFileSizeMb_TextBox"
                                         Grid.Column="1"
                                         Width="120"
                                         MaxLength="3"
                                         HorizontalAlignment="Left"
                                         LostFocus="MaxLogFileSizeMb_TextBox_LostFocus"
                                         PreviewKeyDown="IntegerSetting_TextBox_PreviewKeyDown"
                                         PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                         DataObject.Pasting="IntegerTextBox_Pasting"/>
                                <TextBlock Grid.Column="2"
                                           Text="MB 以内"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>

                                <TextBlock Grid.Row="1"
                                           Text="最多保存数量"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <TextBox x:Name="MaxLogFileCount_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Width="120"
                                         MaxLength="2"
                                         HorizontalAlignment="Left"
                                         LostFocus="MaxLogFileCount_TextBox_LostFocus"
                                         PreviewKeyDown="IntegerSetting_TextBox_PreviewKeyDown"
                                         PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                         DataObject.Pasting="IntegerTextBox_Pasting"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="个文件（含当前日志）"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="Appearance_Section"
                              Header="外观"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="标点编辑显示形式"
                                       Style="{StaticResource SettingsFormLabelStyle}"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <controls:SegmentedSwitchControl x:Name="WayMarkLabelDisplayMode_SegmentedSwitch"
                                                                 LeftText="图片"
                                                                 LeftToolTip="使用项目图片显示 A/B/C/D 和 1/2/3/4 标点"
                                                                 RightText="文字"
                                                                 RightToolTip="使用 A点、B点 等文字显示"
                                                                 VerticalAlignment="Center"
                                                                 SelectionChanged="WayMarkLabelDisplayMode_SegmentedSwitch_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                    <GroupBox x:Name="WayMarkFavorites_Section"
                              Header="标点收藏"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="保存方式"
                                       Style="{StaticResource SettingsFormLabelStyle}"/>
                            <StackPanel Grid.Column="1">
                                <controls:SegmentedSwitchControl x:Name="WayMarkFavoriteSaveMode_SegmentedSwitch"
                                                                 LeftText="手动保存"
                                                                 LeftToolTip="编辑收藏后需要点击保存修改；切换收藏时会提示保存或放弃。"
                                                                 RightText="自动保存"
                                                                 RightToolTip="编辑收藏后自动写入收藏文件，并隐藏保存与放弃按钮。"
                                                                 VerticalAlignment="Center"
                                                                 SelectionChanged="WayMarkFavoriteSaveMode_SegmentedSwitch_SelectionChanged"/>
                                <TextBlock Text="手动保存更适合谨慎编辑；自动保存适合频繁整理收藏。"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="StartupBehavior_Section"
                              Header="启动行为"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="当工具启动后，自动执行哪些操作。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <RadioButton x:Name="StartupLoadRecentWayMarkFile_RadioButton"
                                         GroupName="StartupWayMarkAction"
                                         Content="启动时自动加载最近一次打开的标点文件"
                                         Margin="0,0,0,8"
                                         Checked="StartupWayMarkAction_RadioButton_Checked"/>
                            <RadioButton x:Name="StartupOpenWayMarkFileDialog_RadioButton"
                                         GroupName="StartupWayMarkAction"
                                         Content="启动时自动打开选择标点文件对话框"
                                         Margin="0,0,0,8"
                                         Checked="StartupWayMarkAction_RadioButton_Checked"/>
                            <RadioButton x:Name="StartupDoNothing_RadioButton"
                                         GroupName="StartupWayMarkAction"
                                         Content="启动时不做任何操作"
                                         Checked="StartupWayMarkAction_RadioButton_Checked"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="AutoBackup_Section"
                              Header="自动备份"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="按设置自动创建 UISAVE.DAT 工具备份；自动备份只作用于由游戏安装目录推导出的角色配置目录，临时文件和其他位置的文件会被跳过。清理策略只影响工具生成的备份，不会删除游戏原始文件。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Text="备份时机"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="AutoBackupBeforeSave_CheckBox"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Checked="AutoBackup_CheckChanged"
                                          Unchecked="AutoBackup_CheckChanged"/>
                                <TextBlock Text="保存修改前，备份当前正在编辑的原始 UISAVE.DAT"
                                           VerticalAlignment="Center"
                                           Padding="0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,6,0,0">
                                <CheckBox x:Name="AutoBackupAfterLoad_CheckBox"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Checked="AutoBackup_CheckChanged"
                                          Unchecked="AutoBackup_CheckChanged"/>
                                <TextBlock Text="读取成功后，备份刚刚读取的 UISAVE.DAT"
                                           VerticalAlignment="Center"
                                           Padding="0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,6,0,0">
                                <CheckBox x:Name="AutoBackupBeforeRestore_CheckBox"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Checked="AutoBackup_CheckChanged"
                                          Unchecked="AutoBackup_CheckChanged"/>
                                <TextBlock Text="还原到原文件路径前，备份即将被覆盖的当前 UISAVE.DAT"
                                           VerticalAlignment="Center"
                                           Padding="0"/>
                            </StackPanel>

                            <Separator Margin="0,12,0,12"/>

                            <TextBlock Text="自动清理"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <TextBlock Text="达到数量上限后会从最老的备份开始删除；关闭所有自动备份后仍会保留这些数值，重新启用时继续生效。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <CheckBox x:Name="LimitBackupCount_CheckBox"
                                          Content="限制总备份数量"
                                          Width="180"
                                          VerticalAlignment="Center"
                                          Checked="BackupLimit_CheckChanged"
                                          Unchecked="BackupLimit_CheckChanged"/>
                                <TextBox x:Name="MaxBackupCount_TextBox"
                                         Width="120"
                                         MaxLength="5"
                                         LostFocus="MaxBackupCount_TextBox_LostFocus"
                                         PreviewKeyDown="IntegerSetting_TextBox_PreviewKeyDown"
                                         PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                         DataObject.Pasting="IntegerTextBox_Pasting"/>
                                <TextBlock Text="个以内"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <CheckBox x:Name="LimitBackupCountPerUser_CheckBox"
                                          Content="限制单个玩家备份数量"
                                          Width="180"
                                          VerticalAlignment="Center"
                                          Checked="BackupLimit_CheckChanged"
                                          Unchecked="BackupLimit_CheckChanged"/>
                                <TextBox x:Name="MaxBackupCountPerUser_TextBox"
                                         Width="120"
                                         MaxLength="5"
                                         LostFocus="MaxBackupCountPerUser_TextBox_LostFocus"
                                         PreviewKeyDown="IntegerSetting_TextBox_PreviewKeyDown"
                                         PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                         DataObject.Pasting="IntegerTextBox_Pasting"/>
                                <TextBlock Text="个以内（每个玩家 ID）"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="LimitBackupDays_CheckBox"
                                          Content="限制备份时间"
                                          Width="180"
                                          VerticalAlignment="Center"
                                          Checked="BackupLimit_CheckChanged"
                                          Unchecked="BackupLimit_CheckChanged"/>
                                <TextBox x:Name="MaxBackupDays_TextBox"
                                         Width="120"
                                         MaxLength="4"
                                         LostFocus="MaxBackupDays_TextBox_LostFocus"
                                         PreviewKeyDown="IntegerSetting_TextBox_PreviewKeyDown"
                                         PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                         DataObject.Pasting="IntegerTextBox_Pasting"/>
                                <TextBlock Text="天以内"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="OnlineData_Section"
                              Header="数据同步"
                              Style="{StaticResource SettingsSectionGroupBoxStyle}">
                        <StackPanel>
                            <TextBlock Text="启动工具时只会确认地图数据可用；服务器列表会在进入或编辑角色备注时按需检查，不影响标点编辑启动。为减轻服务器压力，手动检查每类数据 1 分钟内只能成功触发一次；检查失败不会进入频率限制。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Text="地图数据"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <TextBlock Text="自动检查：每次启动会读取远端版本；版本与本地缓存一致时只记录检查时间，版本变化或缓存不可用时才下载完整地图数据。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="0,-4,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="版本"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataVersion_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Column="2"
                                           Text="内容"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataSummary_TextBox"
                                         Grid.Column="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Text="上次更新时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataUpdatedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="上次成功检查时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataCheckedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="版本来源"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataVersionSource_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                                <Button x:Name="RefreshMapData_Button"
                                        Grid.Column="2"
                                        Grid.RowSpan="2"
                                        Content="检查更新"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Click="RefreshMapData_Button_Click"/>

                                <TextBlock Grid.Row="1"
                                           Text="内容来源"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataContentSource_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                            </Grid>

                            <Separator Margin="0,14,0,12"/>

                            <TextBlock Text="服务器列表"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <TextBlock Text="自动检查：进入角色备注页，或从备份创建、编辑角色备注时按需同步；已有缓存时每 7 天最多自动同步一次。在线同步失败但缓存可用时，会继续使用本地缓存。"
                                       Style="{StaticResource SettingsMutedTextStyle}"
                                       Margin="0,-4,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="内容"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListStatus_TextBox"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Text="上次更新时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListUpdatedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="上次成功检查时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListCheckedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="来源"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListSource_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                                <Button x:Name="RefreshServerList_Button"
                                        Grid.Column="2"
                                        Content="检查更新"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Click="RefreshServerList_Button_Click"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
