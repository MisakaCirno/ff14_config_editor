<UserControl x:Class="UIMarkerEditor.Controls.ToolSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UIMarkerEditor.Controls">
    <UserControl.Resources>
        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SettingsSubsectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SettingsSectionDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SettingsSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SettingsFormLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4,12,4"/>
        </Style>

        <Style x:Key="SettingsDataSyncLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsFormLabelStyle}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
        </Style>

        <Style x:Key="SettingsNavigationItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AppAccentPressedBrush}"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppSelectionBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsMutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>

        <Style x:Key="SettingsReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="4"
                Margin="0,0,8,0"
                VerticalAlignment="Stretch">
            <ListBox x:Name="SettingsNavigation_ListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource SettingsNavigationItemStyle}"
                     SelectionChanged="SettingsNavigation_ListBox_SelectionChanged">
                <ListBoxItem Content="配置路径" Tag="DataStorage_Section" Style="{StaticResource SettingsNavigationItemStyle}"/>
                <ListBoxItem Content="日志" Tag="Log_Section" Style="{StaticResource SettingsNavigationItemStyle}"/>
                <ListBoxItem Content="外观" Tag="Appearance_Section" Style="{StaticResource SettingsNavigationItemStyle}"/>
                <ListBoxItem Content="启动行为" Tag="StartupBehavior_Section" Style="{StaticResource SettingsNavigationItemStyle}"/>
                <ListBoxItem Content="自动保存" Tag="AutoBackup_Section" Style="{StaticResource SettingsNavigationItemStyle}"/>
                <ListBoxItem Content="数据同步" Tag="OnlineData_Section" Style="{StaticResource SettingsNavigationItemStyle}"/>
            </ListBox>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="SettingsContent_ScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="SettingsContent_ScrollViewer_ScrollChanged">
                <StackPanel>
                    <Border x:Name="DataStorage_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.ColumnSpan="5"
                                       Text="配置路径"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="5"
                                       Text="软件配置、角色备注、服务器列表缓存、地图数据缓存和 UISAVE.DAT 备份都会保存在这里；不改变游戏安装目录。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Grid.Row="2"
                                       Text="数据目录"
                                       Style="{StaticResource SettingsFormLabelStyle}"/>
                            <TextBox x:Name="DataDirectory_TextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>
                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Content="选择..."
                                    Click="BrowseDataDirectory_Button_Click"/>
                            <Button Grid.Row="2"
                                    Grid.Column="3"
                                    Content="恢复默认"
                                    Click="ResetDataDirectory_Button_Click"/>
                            <Button Grid.Row="2"
                                    Grid.Column="4"
                                    Content="打开已保存目录"
                                    Click="OpenDataDirectory_Button_Click"/>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="4"
                                       Text="更换目录并保存时，可选择迁移现有工具数据，或只切换到一个新的空目录。"
                                       Style="{StaticResource SettingsMutedTextStyle}"/>
                        </Grid>
                    </Border>

                    <Border x:Name="Log_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="日志"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Text="日志保存在配置路径下的 logs 目录，用于排查同步、读取和保存问题。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="单个文件大小"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <TextBox x:Name="MaxLogFileSizeMb_TextBox"
                                         Grid.Column="1"/>
                                <TextBlock Text="MB 以内"
                                           Grid.Column="2"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>

                                <TextBlock Grid.Row="1"
                                           Text="最多保存数量"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <TextBox x:Name="MaxLogFileCount_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="个文件（含当前日志）"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Appearance_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="外观"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Text="调整工具界面的显示方式，不影响保存到 UISAVE.DAT 的数据。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="标点标签"
                                           Style="{StaticResource SettingsFormLabelStyle}"/>
                                <controls:SegmentedSwitchControl x:Name="WayMarkLabelDisplayMode_SegmentedSwitch"
                                                                 Grid.Column="1"
                                                                 LeftText="图片"
                                                                 LeftToolTip="使用项目图片显示 A/B/C/D 和 1/2/3/4 标点"
                                                                 RightText="文字"
                                                                 RightToolTip="使用 A点、B点 等文字显示"
                                                                 VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="StartupBehavior_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="启动行为"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Text="选择工具启动后是否自动处理标点文件；这些操作只会加载或选择文件，不会自动保存修改。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <RadioButton x:Name="StartupLoadRecentWayMarkFile_RadioButton"
                                         GroupName="StartupWayMarkAction"
                                         Content="启动时自动加载最近一次打开的标点文件"
                                         Margin="0,0,0,8"/>
                            <RadioButton x:Name="StartupOpenWayMarkFileDialog_RadioButton"
                                         GroupName="StartupWayMarkAction"
                                         Content="启动时自动打开选择标点文件对话框"
                                         Margin="0,0,0,8"/>
                            <RadioButton x:Name="StartupDoNothing_RadioButton"
                                         GroupName="StartupWayMarkAction"
                                         Content="启动时不做任何操作"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AutoBackup_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="自动保存"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Text="保存当前 UISAVE.DAT 前先创建工具备份；清理策略只影响工具生成的备份，不会删除游戏原始文件。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Text="自动保存"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="AutoBackup_CheckBox"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Checked="AutoBackup_CheckChanged"
                                          Unchecked="AutoBackup_CheckChanged"/>
                                <TextBlock Text="保存修改前自动备份原始 UISAVE.DAT"
                                           VerticalAlignment="Center"
                                           Padding="0"/>
                            </StackPanel>

                            <Separator Margin="0,12,0,12"/>

                            <TextBlock Text="自动清理"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <TextBlock Text="关闭自动备份后仍会保留这些数值，重新启用时继续生效。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <CheckBox x:Name="LimitBackupCount_CheckBox"
                                          Content="限制备份数量"
                                          Width="150"
                                          VerticalAlignment="Center"
                                          Checked="BackupLimit_CheckChanged"
                                          Unchecked="BackupLimit_CheckChanged"/>
                                <TextBox x:Name="MaxBackupCount_TextBox"
                                         Width="120"/>
                                <TextBlock Text="个以内"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="LimitBackupDays_CheckBox"
                                          Content="限制备份时间"
                                          Width="150"
                                          VerticalAlignment="Center"
                                          Checked="BackupLimit_CheckChanged"
                                          Unchecked="BackupLimit_CheckChanged"/>
                                <TextBox x:Name="MaxBackupDays_TextBox"
                                         Width="120"/>
                                <TextBlock Text="天以内"
                                           Style="{StaticResource SettingsMutedTextStyle}"
                                           Margin="8,4,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="OnlineData_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="数据同步"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Text="地图名称和服务器列表会自动检查并缓存到本地；手动检查每类数据 5 分钟内只能触发一次。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Text="地图数据"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="版本"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataVersion_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Column="2"
                                           Text="内容"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataSummary_TextBox"
                                         Grid.Column="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Text="上次更新时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataUpdatedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="上次成功检查时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataCheckedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="版本来源"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataVersionSource_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                                <Button x:Name="RefreshMapData_Button"
                                        Grid.Column="2"
                                        Grid.RowSpan="2"
                                        Content="检查更新"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Click="RefreshMapData_Button_Click"/>

                                <TextBlock Grid.Row="1"
                                           Text="内容来源"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="MapDataContentSource_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                            </Grid>

                            <Separator Margin="0,14,0,12"/>

                            <TextBlock Text="服务器列表"
                                       Style="{StaticResource SettingsSubsectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="内容"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListStatus_TextBox"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Text="上次更新时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListUpdatedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="上次成功检查时间"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListCheckedAt_TextBox"
                                         Grid.Row="1"
                                         Grid.Column="3"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="来源"
                                           Style="{StaticResource SettingsDataSyncLabelStyle}"/>
                                <TextBox x:Name="ServerListSource_TextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingsReadOnlyTextBoxStyle}"/>
                                <Button x:Name="RefreshServerList_Button"
                                        Grid.Column="2"
                                        Content="检查更新"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Click="RefreshServerList_Button_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="保存设置"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveSettings_Button_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
