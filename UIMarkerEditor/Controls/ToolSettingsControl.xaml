<UserControl x:Class="UIMarkerEditor.Controls.ToolSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SettingsSectionDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SettingsSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Column="0"
                  Header="设置"
                  Padding="5"
                  Margin="0,0,8,0">
            <ListBox x:Name="SettingsNavigation_ListBox"
                     BorderThickness="0"
                     SelectionChanged="SettingsNavigation_ListBox_SelectionChanged">
                <ListBoxItem Content="本地数据" Tag="DataStorage_Section"/>
                <ListBoxItem Content="自动备份" Tag="AutoBackup_Section"/>
                <ListBoxItem Content="在线数据缓存" Tag="OnlineData_Section"/>
            </ListBox>
        </GroupBox>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="SettingsContent_ScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border x:Name="DataStorage_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.ColumnSpan="4"
                                       Text="本地数据"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="4"
                                       Text="软件配置、角色备注、服务器列表缓存、地图数据缓存和 UISAVE.DAT 备份都会保存在这里。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Grid.Row="2"
                                       Text="数据目录："/>
                            <TextBox x:Name="DataDirectory_TextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>
                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Content="选择..."
                                    Click="BrowseDataDirectory_Button_Click"/>
                            <Button Grid.Row="2"
                                    Grid.Column="3"
                                    Content="恢复默认"
                                    Click="ResetDataDirectory_Button_Click"/>
                        </Grid>
                    </Border>

                    <Border x:Name="AutoBackup_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.ColumnSpan="4"
                                       Text="自动备份"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="4"
                                       Text="保存文件前先备份原始 UISAVE.DAT；旧备份可以按数量或天数自动清理。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Grid.Row="2"
                                       Text="保存前备份："/>
                            <CheckBox x:Name="AutoBackup_CheckBox"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      Content="启用"
                                      VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3"
                                       Text="按数量清理："/>
                            <CheckBox x:Name="LimitBackupCount_CheckBox"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Content="启用"
                                      VerticalAlignment="Center"
                                      Checked="BackupLimit_CheckChanged"
                                      Unchecked="BackupLimit_CheckChanged"/>
                            <TextBox x:Name="MaxBackupCount_TextBox"
                                     Grid.Row="3"
                                     Grid.Column="2"/>
                            <TextBlock Grid.Row="3"
                                       Grid.Column="3"
                                       Text="个备份"
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="4"
                                       Text="按天数清理："/>
                            <CheckBox x:Name="LimitBackupDays_CheckBox"
                                      Grid.Row="4"
                                      Grid.Column="1"
                                      Content="启用"
                                      VerticalAlignment="Center"
                                      Checked="BackupLimit_CheckChanged"
                                      Unchecked="BackupLimit_CheckChanged"/>
                            <TextBox x:Name="MaxBackupDays_TextBox"
                                     Grid.Row="4"
                                     Grid.Column="2"/>
                            <TextBlock Grid.Row="4"
                                       Grid.Column="3"
                                       Text="天"
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>

                    <Border x:Name="OnlineData_Section"
                            Style="{StaticResource SettingsSectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.ColumnSpan="4"
                                       Text="在线数据缓存"
                                       Style="{StaticResource SettingsSectionTitleStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="4"
                                       Text="地图数据和服务器列表会自动同步并缓存到本地；手动刷新每类数据 5 分钟内只能触发一次。"
                                       Style="{StaticResource SettingsSectionDescriptionStyle}"/>

                            <TextBlock Grid.Row="2"
                                       Text="地图版本："/>
                            <TextBox x:Name="MapDataVersion_TextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="3"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>

                            <TextBlock Grid.Row="3"
                                       Text="地图手动刷新："/>
                            <TextBox x:Name="MapDataRefreshStatus_TextBox"
                                     Grid.Row="3"
                                     Grid.Column="1"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>
                            <Button x:Name="RefreshMapData_Button"
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Content="刷新地图数据"
                                    Click="RefreshMapData_Button_Click"/>

                            <TextBlock Grid.Row="4"
                                       Text="服务器列表："/>
                            <TextBox x:Name="ServerListStatus_TextBox"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="3"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>

                            <TextBlock Grid.Row="5"
                                       Text="服务器刷新："/>
                            <TextBox x:Name="ServerListSyncAttempt_TextBox"
                                     Grid.Row="5"
                                     Grid.Column="1"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>
                            <Button x:Name="RefreshServerList_Button"
                                    Grid.Row="5"
                                    Grid.Column="2"
                                    Content="刷新服务器列表"
                                    Click="RefreshServerList_Button_Click"/>

                            <TextBlock Grid.Row="6"
                                       Text="服务器来源："/>
                            <TextBox x:Name="ServerListSource_TextBox"
                                     Grid.Row="6"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="3"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Left"
                                     TextAlignment="Left"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="打开数据目录"
                        Click="OpenDataDirectory_Button_Click"/>
                <Button Content="保存设置"
                        Click="SaveSettings_Button_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
