<UserControl x:Class="UIMarkerEditor.Controls.WayMarkFavoritesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UIMarkerEditor.Controls">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="FavoriteList_Column" Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition x:Name="FavoriteEditor_Column" Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition x:Name="FavoritePreview_Column" Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="5">
                <TextBlock Text="标点收藏列表：" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Row="1" Margin="5">
                <ListBox x:Name="Favorites_ListBox"
                         AllowDrop="True"
                         SelectionChanged="Favorites_ListBox_SelectionChanged"
                         PreviewMouseLeftButtonDown="Favorites_ListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseLeftButtonUp="Favorites_ListBox_PreviewMouseLeftButtonUp"
                         PreviewMouseRightButtonDown="Favorites_ListBox_PreviewMouseRightButtonDown"
                         MouseMove="Favorites_ListBox_MouseMove"
                         DragOver="Favorites_ListBox_DragOver"
                         DragLeave="Favorites_ListBox_DragLeave"
                         Drop="Favorites_ListBox_Drop">
                    <ListBox.ContextMenu>
                        <ContextMenu Opened="Favorites_ContextMenu_Opened"
                                     Closed="Favorites_ContextMenu_Closed">
                            <ContextMenu.Resources>
                                <Style TargetType="{x:Type MenuItem}">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ContextMenu.Resources>
                            <MenuItem Header="&#x5237;&#x65B0;&#x6536;&#x85CF;&#x5217;&#x8868;"
                                      Click="RefreshFavorites_MenuItem_Click"/>
                            <Separator/>
                            <MenuItem x:Name="AddFavorite_MenuItem"
                                      Header="&#x65B0;&#x589E;&#x6536;&#x85CF;"
                                      Click="AddFavorite_Button_Click"/>
                            <MenuItem x:Name="DeleteFavorite_MenuItem"
                                      Header="&#x5220;&#x9664;&#x6536;&#x85CF;"
                                      Click="DeleteFavorite_Button_Click"/>
                            <Separator/>
                            <MenuItem x:Name="MoveFavoriteUp_MenuItem"
                                      Header="&#x4E0A;&#x79FB;"
                                      Click="MoveFavoriteUp_Button_Click"/>
                            <MenuItem x:Name="MoveFavoriteDown_MenuItem"
                                      Header="&#x4E0B;&#x79FB;"
                                      Click="MoveFavoriteDown_Button_Click"/>
                            <Separator/>
                            <MenuItem x:Name="SortFavorites_MenuItem"
                                      Header="&#x6392;&#x5E8F;&#x6807;&#x70B9;">
                                <MenuItem x:Name="SortFavoritesByRegionAscending_MenuItem"
                                          Header="&#x6309;&#x5730;&#x533A;&#x7F16;&#x53F7;&#x5347;&#x5E8F;"
                                          Click="SortFavoritesByRegionAscending_MenuItem_Click"/>
                                <MenuItem x:Name="SortFavoritesByRegionDescending_MenuItem"
                                          Header="&#x6309;&#x5730;&#x533A;&#x7F16;&#x53F7;&#x964D;&#x5E8F;"
                                          Click="SortFavoritesByRegionDescending_MenuItem_Click"/>
                            </MenuItem>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Canvas x:Name="FavoriteDragOverlay_Canvas" IsHitTestVisible="False" ClipToBounds="True">
                    <Border x:Name="FavoriteDropIndicator_Line"
                            Height="3"
                            Background="#FF267DFF"
                            CornerRadius="1.5"
                            Visibility="Collapsed"/>
                    <Border x:Name="FavoriteDragPreview_Border"
                            Background="#F2FFFFFF"
                            BorderBrush="#FF267DFF"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Opacity="0.9"
                            Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                        </Border.Effect>
                        <TextBlock x:Name="FavoriteDragPreview_TextBlock"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                    </Border>
                </Canvas>
            </Grid>
            <Grid Grid.Row="2" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="AddFavorite_Button"
                        Grid.Column="0"
                        Content="&#x65B0;&#x589E;&#x6536;&#x85CF;"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddFavorite_Button_Click"/>
                <Button x:Name="DeleteFavorite_Button"
                        Grid.Column="1"
                        Content="&#x5220;&#x9664;&#x6536;&#x85CF;"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="DeleteFavorite_Button_Click"/>
                <Button x:Name="MoveFavoriteUp_Button"
                        Grid.Column="2"
                        Width="42"
                        MinWidth="0"
                        Padding="0"
                        Content="&#x2191;"
                        ToolTip="&#x4E0A;&#x79FB;"
                        Click="MoveFavoriteUp_Button_Click"/>
                <Button x:Name="MoveFavoriteDown_Button"
                        Grid.Column="3"
                        Width="42"
                        MinWidth="0"
                        Padding="0"
                        Content="&#x2193;"
                        ToolTip="&#x4E0B;&#x79FB;"
                        Click="MoveFavoriteDown_Button_Click"/>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="注释名：" VerticalAlignment="Center"/>
                <TextBox x:Name="CommentName_TextBox"
                          Grid.Column="1"
                          MaxLength="120"
                          TextChanged="CommentName_TextBox_TextChanged"
                          LostKeyboardFocus="CommentName_TextBox_LostKeyboardFocus"/>
            </Grid>

            <controls:WayMarkEditPanelControl x:Name="WayMarkEditPanel_Control"
                                               Grid.Row="1"
                                               ShowClipboardButtons="True"/>
        </Grid>

        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:WayMarkPreviewControl x:Name="Preview_Control"/>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock x:Name="AutoSaveStatus_TextBlock"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Visibility="Collapsed"/>
                <WrapPanel x:Name="ManualSaveButtons_Panel">
                    <Button x:Name="SaveFavorite_Button"
                            Content="保存修改"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="SaveFavorite_Button_Click"/>
                    <Button x:Name="DiscardFavorite_Button"
                            Content="放弃修改"
                            Style="{StaticResource WarningButtonStyle}"
                            Click="DiscardFavorite_Button_Click"/>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
