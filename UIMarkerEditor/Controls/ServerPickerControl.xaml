<UserControl x:Class="UIMarkerEditor.Controls.ServerPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="ServerPicker_Button"
                Grid.Column="0"
                HorizontalContentAlignment="Stretch"
                Click="ServerPicker_Button_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ServerPicker_TextBlock"
                           Text="请选择服务器"
                           TextAlignment="Left"/>
                <TextBlock Grid.Column="1"
                           Text="▼"
                           FontSize="10"
                           Margin="8,0,0,0"/>
            </Grid>
        </Button>

        <Button x:Name="ClearServer_Button"
                Grid.Column="1"
                Width="30"
                Height="30"
                Margin="0,4,4,4"
                Padding="0"
                ToolTip="清空服务器"
                AutomationProperties.Name="清空服务器"
                Click="ClearServer_Button_Click">
            <TextBlock Text="×"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <Popup x:Name="ServerPicker_Popup"
               PlacementTarget="{Binding ElementName=ServerPicker_Button}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               Opened="ServerPicker_Popup_Opened">
            <Border Background="White"
                    BorderBrush="#FF888888"
                    BorderThickness="1"
                    Padding="6"
                    Width="{Binding ActualWidth, ElementName=ServerPicker_Button}"
                    MinWidth="360">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="ServerArea_ListBox"
                              DisplayMemberPath="DataCenter"
                              SelectionChanged="ServerArea_ListBox_SelectionChanged"
                              PreviewKeyDown="ServerArea_ListBox_PreviewKeyDown"/>
                    <ListBox x:Name="ServerWorld_ListBox"
                              Grid.Column="1"
                              PreviewKeyDown="ServerWorld_ListBox_PreviewKeyDown"
                              PreviewMouseLeftButtonUp="ServerWorld_ListBox_PreviewMouseLeftButtonUp"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
