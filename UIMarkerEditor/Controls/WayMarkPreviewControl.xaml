<UserControl x:Class="UIMarkerEditor.Controls.WayMarkPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="标点相对位置预览：" HorizontalAlignment="Left" Margin="5,5,0,0"/>

        <Grid Grid.Row="1"
              x:Name="Preview_Container"
              Background="Transparent"
              Margin="5"
              ClipToBounds="True"
              SizeChanged="Preview_Container_SizeChanged">
            <Canvas x:Name="Preview_Canvas"
                    Background="#FFD5C896"
                    ClipToBounds="True"/>
        </Grid>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="点缩放：" VerticalAlignment="Center"/>
            <Slider x:Name="Scale_Slider"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Minimum="0.05"
                    Maximum="0.5"
                    Value="0.1"
                    ValueChanged="Scale_Slider_ValueChanged"/>
            <TextBlock Text="{Binding Value, ElementName=Scale_Slider, StringFormat={}{0:P0}}"
                       Grid.Column="2"
                       Width="30"
                       TextAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>
