<UserControl x:Class="UIMarkerEditor.Controls.CharacterProfilesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UIMarkerEditor.Controls">
    <Grid x:Name="CharacterRoot_Grid" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="CharacterList_Column" Width="2*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition x:Name="CharacterDetail_Column" Width="3*"/>
        </Grid.ColumnDefinitions>

        <GroupBox x:Name="CharacterList_GroupBox"
                  Grid.Column="0"
                  Header="角色备注列表"
                  Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="Character_DataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          SelectionChanged="Character_DataGrid_SelectionChanged"
                          PreviewMouseRightButtonDown="Character_DataGrid_PreviewMouseRightButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu Opened="Character_ContextMenu_Opened">
                            <MenuItem x:Name="RefreshCharacters_MenuItem"
                                      Header="刷新角色备注"
                                      Click="RefreshCharacters_Button_Click"/>
                            <Separator/>
                            <MenuItem x:Name="NewCharacter_MenuItem"
                                      Header="新建备注"
                                      Click="NewCharacter_Button_Click"/>
                            <MenuItem x:Name="DeleteCharacter_MenuItem"
                                      Header="删除备注"
                                      IsEnabled="False"
                                      Click="DeleteCharacter_Button_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="角色名"
                                            Binding="{Binding CharacterName}"
                                            SortMemberPath="CharacterName"
                                            Width="SizeToCells"
                                            MinWidth="70"/>
                        <DataGridTextColumn Header="大区"
                                            Binding="{Binding DataCenter}"
                                            SortMemberPath="DataCenter"
                                            Width="SizeToCells"
                                            MinWidth="55"/>
                        <DataGridTextColumn Header="服务器"
                                            Binding="{Binding World}"
                                            SortMemberPath="World"
                                            Width="SizeToCells"
                                            MinWidth="70"/>
                        <DataGridTextColumn Header="User ID"
                                            Binding="{Binding UserID}"
                                            SortMemberPath="UserID"
                                            Width="*"
                                            MinWidth="75"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button x:Name="ScanClientLogs_Button"
                            Content="获取所有本地角色"
                            MinWidth="132"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="ScanClientLogs_Button_Click"/>
                    <Button Content="新建备注"
                            MinWidth="96"
                            Height="32"
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="NewCharacter_Button_Click"/>
                    <Button x:Name="DeleteCharacterList_Button"
                            Content="删除备注"
                            MinWidth="96"
                            Height="32"
                            Margin="0"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteCharacter_Button_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GridSplitter x:Name="CharacterGridSplitter"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"/>

        <GroupBox x:Name="CharacterDetail_GroupBox"
                  Grid.Column="2"
                  Header="备注详情"
                  Padding="8">
            <Grid>
                <StackPanel x:Name="CharacterEmpty_Panel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="请选择左侧角色备注进行修改。"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="5"/>
                </StackPanel>

                <ScrollViewer x:Name="CharacterDetail_ScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="User ID：" Grid.Row="0"/>
                        <TextBox x:Name="CharacterUserID_TextBox"
                                 Grid.Row="0"
                                 Grid.Column="1"
                                 IsReadOnly="True"
                                 TextChanged="CharacterDetail_TextChanged"/>
                        <TextBlock Text="角色名：" Grid.Row="1"/>
                        <TextBox x:Name="CharacterName_TextBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 TextChanged="CharacterDetail_TextChanged"/>
                        <TextBlock Text="服务器：" Grid.Row="2"/>
                        <controls:ServerPickerControl x:Name="CharacterServerPicker_Control"
                                                      Grid.Row="2"
                                                      Grid.Column="1"
                                                      SelectedServerChanged="CharacterServerPicker_Control_SelectedServerChanged"/>
                        <TextBlock Text="备注：" Grid.Row="3"/>
                        <TextBox x:Name="CharacterNote_TextBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 TextChanged="CharacterDetail_TextChanged"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="保存备注"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveCharacter_Button_Click"/>
                            <Button x:Name="DeleteCharacter_Button"
                                    Content="删除备注"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="DeleteCharacter_Button_Click"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </GroupBox>

        <controls:BusyOverlayControl x:Name="CharacterBusyOverlay_Control"
                                     Grid.ColumnSpan="3"
                                     Panel.ZIndex="10"/>
    </Grid>
</UserControl>
