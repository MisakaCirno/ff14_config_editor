<UserControl x:Class="UIMarkerEditor.Controls.WayMarkEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:UIMarkerEditor"
             xmlns:controls="clr-namespace:UIMarkerEditor.Controls">
    <UserControl.Resources>
        <local:RegionIdToNameConverter x:Key="RegionIdToNameConverter"/>
    </UserControl.Resources>
    <Grid x:Name="WayMarkRoot_Grid" Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="WayMarkList_Column" Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="WayMarkEditor_Column" Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="WayMarkPreview_Column" Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="标点预设列表：" HorizontalAlignment="Left"/>
                <TextBlock x:Name="DataVersion_TextBlock" Text="当前版本：" HorizontalAlignment="Right" Grid.Column="1" Foreground="Blue"/>
            </Grid>
            <Grid Grid.Row="1" Margin="5">
                <ListBox x:Name="WayMark_ListBox"
                                 AllowDrop="True"
                                 SelectionChanged="WayMark_ListBox_SelectionChanged"
                                 PreviewMouseLeftButtonDown="WayMark_ListBox_PreviewMouseLeftButtonDown"
                                 PreviewMouseLeftButtonUp="WayMark_ListBox_PreviewMouseLeftButtonUp"
                                 PreviewMouseRightButtonDown="WayMark_ListBox_PreviewMouseRightButtonDown"
                                 MouseDoubleClick="WayMark_ListBox_MouseDoubleClick"
                                 MouseMove="WayMark_ListBox_MouseMove"
                                 DragOver="WayMark_ListBox_DragOver"
                                 DragLeave="WayMark_ListBox_DragLeave"
                                 Drop="WayMark_ListBox_Drop">
                    <ListBox.ContextMenu>
                        <ContextMenu Opened="WayMarkContextMenu_Opened"
                                     Closed="WayMarkContextMenu_Closed">
                            <ContextMenu.Resources>
                                <Style TargetType="{x:Type MenuItem}">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ContextMenu.Resources>
                            <MenuItem x:Name="CopyWayMark_MenuItem"
                                      Header="复制标点"
                                      InputGestureText="Ctrl+C"
                                      Click="CopyWayMark_MenuItem_Click"/>
                            <MenuItem x:Name="PasteWayMark_MenuItem"
                                      Header="粘贴到此标点"
                                      InputGestureText="Ctrl+V"
                                      Click="PasteWayMark_MenuItem_Click"/>
                            <Separator/>
                            <MenuItem x:Name="MoveWayMarkUp_MenuItem"
                                      Header="&#x4E0A;&#x79FB;"
                                      Click="MoveUp_Button_Click"/>
                            <MenuItem x:Name="MoveWayMarkDown_MenuItem"
                                      Header="&#x4E0B;&#x79FB;"
                                      Click="MoveDown_Button_Click"/>
                            <Separator/>
                            <MenuItem x:Name="FavoriteWayMark_MenuItem"
                                      Header="收藏标点..."
                                      Click="FavoriteWayMark_MenuItem_Click">
                                <MenuItem.Icon>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="{StaticResource FavoriteIconGeometry}"
                                                  Fill="#FFFFC107"
                                                  Stroke="{StaticResource AppAccentPressedBrush}"
                                                  StrokeThickness="1.7"
                                                  StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="ImportFavoriteWayMark_MenuItem"
                                      Header="从收藏导入..."
                                      Click="ImportFavoriteWayMark_MenuItem_Click"/>
                            <Separator/>
                            <MenuItem x:Name="SortWayMarks_MenuItem"
                                      Header="&#x6392;&#x5E8F;&#x6807;&#x70B9;">
                                <MenuItem x:Name="SortWayMarksByRegionAscending_MenuItem"
                                          Header="&#x6309;&#x5730;&#x533A;&#x7F16;&#x53F7;&#x5347;&#x5E8F;"
                                          Click="SortWayMarksByRegionAscending_MenuItem_Click"/>
                                <MenuItem x:Name="SortWayMarksByRegionDescending_MenuItem"
                                          Header="&#x6309;&#x5730;&#x533A;&#x7F16;&#x53F7;&#x964D;&#x5E8F;"
                                          Click="SortWayMarksByRegionDescending_MenuItem_Click"/>
                            </MenuItem>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RegionID, Converter={StaticResource RegionIdToNameConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RegionID}" Value="0">
                                                <Setter Property="Foreground" Value="DarkGreen"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Canvas x:Name="DragOverlay_Canvas" IsHitTestVisible="False" ClipToBounds="True">
                    <Border x:Name="DropIndicator_Line"
                                    Height="3"
                                    Background="#FF267DFF"
                                    CornerRadius="1.5"
                                    Visibility="Collapsed"/>
                    <Border x:Name="DragPreview_Border"
                                    Background="#F2FFFFFF"
                                    BorderBrush="#FF267DFF"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Opacity="0.9"
                                    Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                        </Border.Effect>
                        <TextBlock x:Name="DragPreview_TextBlock"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"/>
                    </Border>
                </Canvas>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="ShareWebsite_Button" Click="ShareWebsite_Button_Click" Grid.Column="0" Style="{StaticResource InfoButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource ExternalLinkIconGeometry}"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="标点分享网站" Padding="0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="MoveUp_Button" Content="↑" Click="MoveUp_Button_Click" Grid.Column="2"/>
                <Button x:Name="MoveDown_Button" Content="↓" Click="MoveDown_Button_Click" Grid.Column="3"/>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:WayMarkEditPanelControl x:Name="WayMarkEditPanel_Control"
                                               ShowClipboardButtons="True"/>

            <StackPanel Grid.Row="1">
                <TextBlock Foreground="Red" FontWeight="Bold" Text="请【不要】在角色在线时编辑标点文件！"/>
                <TextBlock Foreground="DarkGreen" FontWeight="Bold" Text="只能在【选角界面】或【关闭游戏时】编辑标点文件！"/>
            </StackPanel>
        </Grid>
        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <controls:WayMarkPreviewControl x:Name="WayMarkPreview_Control" Grid.Column="4"/>
    </Grid>
</UserControl>
