<UserControl x:Class="UIMarkerEditor.Controls.BackupRestoreControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UIMarkerEditor.Controls">
    <UserControl.Resources>
        <Style x:Key="BackupFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,8,5,2"/>
        </Style>

        <Style x:Key="BackupReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="5,0,5,4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Background" Value="#FFF8F8F8"/>
            <Setter Property="BorderBrush" Value="#FFBDBDBD"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid x:Name="BackupRoot_Grid" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="BackupList_Column" Width="2*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition x:Name="BackupDetail_Column" Width="3*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Column="0" Header="备份列表" Padding="5">
            <DataGrid x:Name="Backup_DataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      SelectionChanged="Backup_DataGrid_SelectionChanged"
                      MouseDoubleClick="Backup_DataGrid_MouseDoubleClick"
                      PreviewMouseRightButtonDown="Backup_DataGrid_PreviewMouseRightButtonDown">
                <DataGrid.ContextMenu>
                    <ContextMenu Opened="Backup_ContextMenu_Opened">
                        <MenuItem x:Name="RefreshBackups_MenuItem"
                                  Header="刷新备份列表"
                                  Click="RefreshBackups_Button_Click"/>
                        <Separator/>
                        <MenuItem x:Name="RestoreBackup_MenuItem"
                                  Header="还原到原文件路径..."
                                  Click="RestoreBackup_Button_Click"/>
                        <MenuItem x:Name="RestoreBackupAs_MenuItem"
                                  Header="还原到..."
                                  Click="RestoreBackupAs_Button_Click"/>
                        <MenuItem x:Name="DeleteBackup_MenuItem"
                                  Header="删除备份"
                                  Click="DeleteBackup_Button_Click"/>
                        <MenuItem x:Name="OpenBackupDirectory_MenuItem"
                                  Header="打开备份目录"
                                  Click="OpenBackupDirectory_Button_Click"/>
                        <Separator/>
                        <MenuItem x:Name="OpenCharacterProfileFromBackup_MenuItem"
                                  Header="为此备份创建角色备注..."
                                  Click="OpenCharacterProfileFromBackup_MenuItem_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="备份日期"
                                        Binding="{Binding BackupTime, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                        SortMemberPath="BackupTime"
                                        Width="150"/>
                    <DataGridTextColumn Header="来源"
                                        Binding="{Binding CreationTriggerDisplay}"
                                        SortMemberPath="CreationTriggerDisplay"
                                        Width="130"/>
                    <DataGridTextColumn Header="用户名"
                                        Binding="{Binding CharacterNameDisplay}"
                                        SortMemberPath="CharacterNameDisplay"
                                        Width="*"/>
                    <DataGridTextColumn Header="服务器"
                                        Binding="{Binding ServerDisplayName}"
                                        SortMemberPath="ServerDisplayName"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <GroupBox x:Name="BackupDetail_GroupBox"
                  Grid.Column="2"
                  Header="备份详情"
                  Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel x:Name="BackupEmpty_Panel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="请选择左侧备份查看详情。"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="5"/>
                </StackPanel>

                <ScrollViewer x:Name="BackupDetail_ScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="备份时间："
                                           Style="{StaticResource BackupFieldLabelStyle}"
                                           ToolTip="创建这个备份的本地时间。"/>
                                <TextBox x:Name="BackupDetail_BackupTime_TextBox"
                                         Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="角色备注："
                                           Style="{StaticResource BackupFieldLabelStyle}"
                                           ToolTip="根据文件 User ID 或目录 User ID 匹配到的本地角色备注。"/>
                                <TextBox x:Name="BackupDetail_Character_TextBox"
                                         Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="创建原因："
                                   Style="{StaticResource BackupFieldLabelStyle}"
                                   ToolTip="记录这个备份是由保存前、读取后、还原前安全保护，还是删除文件重建后自动创建。"/>
                        <TextBox x:Name="BackupDetail_CreationTrigger_TextBox"
                                 Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="目录 User ID："
                                           Style="{StaticResource BackupFieldLabelStyle}"
                                           ToolTip="从 FFXIV_CHRxxxxxxxxxxxxxxxx 角色目录名中读取到的 User ID。"/>
                                <TextBox x:Name="BackupDetail_FolderUserID_TextBox"
                                         Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="文件 User ID："
                                           Style="{StaticResource BackupFieldLabelStyle}"
                                           ToolTip="从 UISAVE.DAT 文件内容中读取到的 User ID。"/>
                                <TextBox x:Name="BackupDetail_FileUserID_TextBox"
                                         Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="地图标点快照："
                                   Style="{StaticResource BackupFieldLabelStyle}"
                                   ToolTip="按原文件中的标点槽位顺序逐条记录；只展示地图与启用标点数量，不包含具体坐标。"/>
                        <TextBox x:Name="BackupSnapshot_TextBox"
                                 MinHeight="140"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>

                        <TextBlock Text="原文件路径："
                                   Style="{StaticResource BackupFieldLabelStyle}"
                                   ToolTip="备份创建时，原 UISAVE.DAT 文件所在的完整路径。"/>
                        <TextBox x:Name="BackupDetail_OriginalPath_TextBox"
                                 Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>

                        <TextBlock Text="备份文件路径："
                                   Style="{StaticResource BackupFieldLabelStyle}"
                                   ToolTip="这个备份保存的 UISAVE.DAT 文件完整路径。"/>
                        <TextBox x:Name="BackupDetail_BackupFile_TextBox"
                                 Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>

                        <TextBlock Text="文件大小："
                                   Style="{StaticResource BackupFieldLabelStyle}"
                                   ToolTip="备份创建时，原文件的字节大小。"/>
                        <TextBox x:Name="BackupDetail_SourceFileSize_TextBox"
                                 Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>

                        <TextBlock Text="SHA256："
                                   Style="{StaticResource BackupFieldLabelStyle}"
                                   ToolTip="备份创建时，原文件内容计算得到的 SHA256 摘要，用于辅助确认文件是否一致。"/>
                        <TextBox x:Name="BackupDetail_SourceSha256_TextBox"
                                 Style="{StaticResource BackupReadOnlyTextBoxStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                    <Button x:Name="RestoreBackup_Button"
                            Content="还原到原文件路径..."
                            Click="RestoreBackup_Button_Click"/>
                    <Button x:Name="RestoreBackupAs_Button"
                            Content="还原到..."
                            Click="RestoreBackupAs_Button_Click"/>
                    <Button x:Name="DeleteBackup_Button"
                            Content="删除备份"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteBackup_Button_Click"/>
                    <Button x:Name="OpenBackupDirectory_Button"
                            Content="打开备份目录"
                            Click="OpenBackupDirectory_Button_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        </Grid>

        <controls:BusyOverlayControl x:Name="BackupBusyOverlay_Control"/>
    </Grid>
</UserControl>
