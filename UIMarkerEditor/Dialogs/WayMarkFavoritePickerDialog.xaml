<Window x:Class="UIMarkerEditor.WayMarkFavoritePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UIMarkerEditor.Controls"
        Title="&#x4ECE;&#x6536;&#x85CF;&#x5BFC;&#x5165;&#x6807;&#x70B9;"
        Height="560"
        Width="760"
        MinHeight="500"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppDialogWindowStyle}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="FavoritePickerList_Column" Width="3*" MinWidth="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition x:Name="FavoritePickerPreview_Column" Width="2*" MinWidth="260"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="&#x6536;&#x85CF;&#x5217;&#x8868;" Padding="5">
            <DataGrid x:Name="Favorites_DataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      MouseDoubleClick="Favorites_DataGrid_MouseDoubleClick"
                      SelectionChanged="Favorites_DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="&#x6CE8;&#x91CA;&#x540D;"
                                        Binding="{Binding DisplayName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="&#x533A;&#x57DF;"
                                        Binding="{Binding RegionDisplayName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="&#x542F;&#x7528;"
                                        Binding="{Binding EnabledPointCount}"
                                        Width="60"/>
                    <DataGridTextColumn Header="&#x66F4;&#x65B0;&#x65E5;&#x671F;"
                                        Binding="{Binding UpdatedAt, StringFormat=yyyy-MM-dd HH:mm}"
                                        Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <GroupBox Grid.Column="2" Header="&#x9884;&#x89C8;" Padding="5">
            <controls:WayMarkPreviewControl x:Name="Preview_Control"/>
        </GroupBox>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="Ok_Button"
                    Content="&#x5BFC;&#x5165;"
                    Width="96"
                    Height="32"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="Ok_Button_Click"/>
            <Button Content="&#x53D6;&#x6D88;"
                    Width="96"
                    Height="32"
                    Margin="0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
