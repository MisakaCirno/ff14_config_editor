<Window x:Class="UIMarkerEditor.UserMapDataEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑用户填写地图数据"
        Height="540"
        Width="760"
        MinHeight="460"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppDialogWindowStyle}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="Description_TextBlock"
                   Text="编辑 mapdata_user.csv。每行填写一个地图 ID 和名称；保存后，切换到“用户填写数据”或重新读取即可使用这些地图数据。"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1"
              Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SourceLabel_TextBlock"
                       Text="文件"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBox x:Name="FilePath_TextBox"
                     Grid.Column="1"
                     IsReadOnly="True"
                     HorizontalContentAlignment="Left"
                     TextAlignment="Left"/>
        </Grid>

        <DataGrid x:Name="MapDataRows_DataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Extended"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="地图 ID"
                                    Binding="{Binding MapId, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120"/>
                <DataGridTextColumn Header="名称"
                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="Add_Button"
                        Content="添加"
                        Width="88"
                        Click="Add_Button_Click"/>
                <Button x:Name="DeleteSelected_Button"
                        Content="删除选中"
                        Width="96"
                        Click="DeleteSelected_Button_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button x:Name="Save_Button"
                        Content="保存"
                        Width="96"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="Save_Button_Click"/>
                <Button x:Name="Close_Button"
                        Content="取消"
                        Width="96"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
