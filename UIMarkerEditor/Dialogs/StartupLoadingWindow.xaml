<Window x:Class="UIMarkerEditor.StartupLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在启动"
        Width="456"
        Height="230"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="StartupProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="10"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  Opacity="0.18"
                                  ShadowDepth="6"
                                  Color="#FF000000"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="82"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource AppAccentPressedBrush}"
                        CornerRadius="9,9,0,0">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="42"
                                Height="42"
                                Background="{DynamicResource AppSurfaceBrush}"
                                CornerRadius="21"
                                Opacity="0.95"
                                VerticalAlignment="Center">
                            <TextBlock Text="XIV"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppAccentPressedBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Padding="0"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="FF14 标点预设编辑工具"
                                       HorizontalAlignment="Left"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Padding="0"/>
                            <TextBlock Text="正在准备编辑环境"
                                       HorizontalAlignment="Left"
                                       Margin="0,6,0,0"
                                       Foreground="#DDEAF2F7"
                                       Padding="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,20,24,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource AppBackgroundBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="12,10">
                        <TextBlock x:Name="Status_TextBlock"
                                   HorizontalAlignment="Left"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="正在准备..."
                                   TextWrapping="Wrap"
                                   Padding="0"/>
                    </Border>

                    <ProgressBar Grid.Row="1"
                                 Margin="0,16,0,0"
                                 IsIndeterminate="True"
                                 Style="{StaticResource StartupProgressBarStyle}"/>
                </Grid>

                <Border Grid.Row="2"
                        Height="1"
                        Margin="24,0"
                        Background="{DynamicResource AppBorderBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
