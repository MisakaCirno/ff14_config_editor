<Window x:Class="UIMarkerEditor.WayMarkFavoriteNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x6536;&#x85CF;&#x6807;&#x70B9;"
        Height="218"
        Width="520"
        MinHeight="218"
        MinWidth="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppDialogWindowStyle}">
    <Grid Margin="18,14,18,16" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="Hint_TextBlock"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1"
                   Text="&#x6CE8;&#x91CA;&#x540D;&#xFF1A;"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="CommentName_TextBox"
                 Grid.Row="2"
                 MaxLength="120"
                 Height="32"
                 HorizontalContentAlignment="Left"
                 VerticalContentAlignment="Center"
                 Margin="0"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="&#x786E;&#x5B9A;"
                    Width="96"
                    Height="32"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="Ok_Button_Click"/>
            <Button Content="&#x53D6;&#x6D88;"
                    Width="96"
                    Height="32"
                    Margin="0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>