<Window x:Class="UIMarkerEditor.LocalGameCharacterPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择游戏角色"
        Height="460"
        Width="720"
        MinHeight="380"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppDialogWindowStyle}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="Characters_DataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="Characters_DataGrid_MouseDoubleClick"
                  SelectionChanged="Characters_DataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="角色名"
                                    Binding="{Binding CharacterName}"
                                    Width="*"
                                    MinWidth="120"/>
                <DataGridTextColumn Header="User ID"
                                    Binding="{Binding UserID}"
                                    Width="170"/>
                <DataGridTextColumn Header="服务器"
                                    Binding="{Binding ServerDisplayName}"
                                    Width="150"/>
                <DataGridTextColumn Header="UISAVE 修改时间"
                                    Binding="{Binding SaveFileLastWriteTimeDisplay}"
                                    Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="Ok_Button"
                    Content="打开"
                    Width="96"
                    Height="32"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="Ok_Button_Click"/>
            <Button Content="取消"
                    Width="96"
                    Height="32"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
