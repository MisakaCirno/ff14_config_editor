<Window x:Class="FF14LogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FF14 日志查看器"
        Width="1180"
        Height="760"
        MinWidth="960"
        MinHeight="620">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="日志目录" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         x:Name="DirectoryTextBox"
                         MinWidth="320"
                         TextWrapping="NoWrap"/>
                <Button Grid.Column="2"
                        x:Name="BrowseButton"
                        Content="浏览"
                        Margin="8,0,0,0"
                        Click="BrowseButton_Click"/>
                <TextBlock Grid.Column="3" Text="最近" Margin="14,0,6,0"/>
                <TextBox Grid.Column="4"
                         x:Name="RecentCountTextBox"
                         Width="74"
                         Text="1000"/>
                <Button Grid.Column="5"
                        x:Name="LoadRecentButton"
                        Content="读取"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="8,0,0,0"
                        Click="LoadRecentButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="关键词" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         x:Name="QueryTextBox"
                         MinWidth="260"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Kind" Margin="14,0,6,0"/>
                <TextBox Grid.Row="0"
                         Grid.Column="3"
                         x:Name="KindTextBox"
                         Width="70"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="最多" Margin="14,0,6,0"/>
                <TextBox Grid.Row="0"
                         Grid.Column="5"
                         x:Name="MaxResultsTextBox"
                         Width="84"
                         Text="1000"/>
                <StackPanel Grid.Row="0"
                            Grid.Column="6"
                            Orientation="Horizontal"
                            Margin="10,0,0,0">
                    <Button x:Name="SearchButton"
                            Content="搜索"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SearchButton_Click"/>
                    <Button x:Name="ShowAllButton"
                            Content="全部"
                            Margin="8,0,0,0"
                            Click="ShowAllButton_Click"/>
                    <Button x:Name="CancelButton"
                            Content="取消"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="CancelButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="6"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <CheckBox x:Name="SearchSenderCheckBox" Content="发送者" IsChecked="True"/>
                    <CheckBox x:Name="SearchBodyCheckBox" Content="正文" IsChecked="True"/>
                    <CheckBox x:Name="NewestFirstCheckBox" Content="最新优先" IsChecked="True"/>
                    <CheckBox x:Name="CaseSensitiveCheckBox" Content="区分大小写"/>
                    <CheckBox x:Name="RegexCheckBox" Content="正则"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  x:Name="LogDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding LocalTime}" Width="150"/>
                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="64"/>
                <DataGridTextColumn Header="发送者" Binding="{Binding Sender}" Width="180"/>
                <DataGridTextColumn Header="正文" Binding="{Binding Body}" Width="*"/>
                <DataGridTextColumn Header="文件" Binding="{Binding FileName}" Width="110"/>
                <DataGridTextColumn Header="序号" Binding="{Binding EntryIndex}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,10,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="0"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="就绪"/>
            <ProgressBar x:Name="ProgressBar"
                         Grid.Column="1"
                         Height="8"
                         IsIndeterminate="False"
                         Visibility="Collapsed"/>
        </Grid>

        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="错误"
                           FontWeight="SemiBold"
                           Margin="10,8,10,4"/>
                <ListBox x:Name="ErrorListBox"
                         BorderThickness="0"
                         Margin="6,0,6,6"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
